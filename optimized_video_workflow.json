{
  "workflow_name": "Optimized Video Generation",
  "description": "Fast and longer video generation workflow",
  "nodes": {
    "checkpoint_loader": {
      "type": "CheckpointLoaderSimple",
      "settings": {
        "ckpt_name": "sd_xl_base_1.0.safetensors",
        "note": "Use lighter models like SD 1.5 for faster generation"
      }
    },
    "clip_text_encode_positive": {
      "type": "CLIPTextEncode",
      "settings": {
        "text": "Your positive prompt here"
      }
    },
    "clip_text_encode_negative": {
      "type": "CLIPTextEncode", 
      "settings": {
        "text": "blurry, low quality, distorted, bad anatomy"
      }
    },
    "ksampler": {
      "type": "KSampler",
      "optimized_settings": {
        "seed": -1,
        "steps": 15,
        "cfg": 7.0,
        "sampler_name": "dpmpp_2m_karras",
        "scheduler": "karras",
        "denoise": 1.0,
        "note": "Reduced from 25+ steps to 15 for 40% speed improvement"
      }
    },
    "video_generation": {
      "type": "AnimateDiffLoader",
      "optimized_settings": {
        "model_name": "animatediff_v2.safetensors",
        "frame_count": 72,
        "fps": 12,
        "context_length": 16,
        "note": "Increased from 24 frames to 72 frames for 3x longer video"
      }
    },
    "latent_upscale": {
      "type": "LatentUpscale",
      "settings": {
        "upscale_method": "nearest-exact",
        "width": 768,
        "height": 768,
        "crop": "disabled",
        "note": "Start with lower resolution, upscale if needed"
      }
    },
    "vae_decode": {
      "type": "VAEDecode",
      "settings": {
        "note": "Use tiled VAE decode for large videos to save VRAM"
      }
    }
  },
  "optimization_recommendations": {
    "immediate_speed_gains": [
      "Reduce sampling steps from 25-50 to 15-20",
      "Change sampler to DPM++ 2M Karras",
      "Lower CFG scale from 10-15 to 6-8",
      "Use 512x512 or 768x768 initial resolution"
    ],
    "length_improvements": [
      "Increase frame count from 24 to 72-144",
      "Use AnimateDiff with longer context windows",
      "Implement batch generation for very long videos",
      "Use video conditioning for temporal consistency"
    ],
    "hardware_optimizations": [
      "Enable model CPU offloading",
      "Use FP16 precision",
      "Clear VRAM between generations",
      "Use tiled processing for large videos"
    ]
  },
  "model_alternatives": {
    "for_speed": [
      "SD 1.5 + AnimateDiff",
      "LCM (Latent Consistency Models)", 
      "SDXL-Turbo",
      "Lightning models"
    ],
    "for_length": [
      "Stable Video Diffusion (SVD)",
      "I2VGen-XL",
      "CogVideoX",
      "AnimateDiff with sliding window"
    ]
  },
  "expected_improvements": {
    "speed": "2-5x faster generation",
    "length": "3-6x longer videos (15-30 seconds)",
    "quality": "Maintained with proper settings",
